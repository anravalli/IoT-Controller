# 1. Base image leggera
FROM python:3.13-slim

# 2. Impedisce a Python di generare file .pyc e forza il flush dei log
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# 3. Installazione dipendenze (sfruttiamo la cache dei layer)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 4. Copia del codice sorgente
COPY ./iot-controller-be.py .

# 5. Non eseguiamo come root (Best practice di sicurezza per Azure)
RUN adduser --disabled-password --gecos "" appuser && chown -R appuser /app
USER appuser

# 6. Porta esposta (Azure Container Apps la userà per l'Ingress)
EXPOSE 8000

# 7. Avvio con Uvicorn (standard per FastAPI)
CMD ["uvicorn", "iot-controller-be:app", "--host", "0.0.0.0", "--port", "8000"]
